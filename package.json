    "@react-navigation/native-stack": "^6.9.26",
    "expo": "^55.0.11",
    "firebase": "^12.11.0",
    "nativewind": "^4.2.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-native": "^0.81.5",
    "react-native-calendars": "^1.1314.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-uuid": "^2.0.4",
    "react-native-web": "^0.21.2",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
